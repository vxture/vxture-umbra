# worker-03 deployment runtime overrides.
# Optional worker-03 env overlay.
# The repository root .env remains required for full runtime configuration.
# Copy this file to deploy/worker-03/.env only when this deployment package
# needs worker-specific overrides.

IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest

# Optional registry login values for manual runs.
# CI/CD injects registry credentials through GitHub Actions secrets.
# REGISTRY_USERNAME=
# REGISTRY_PASSWORD=
