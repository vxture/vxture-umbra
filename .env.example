# -- Node Identity -------------------------------------------------------------
PROJECT_NAME=umbra
NODE_NAME=vx-tokyo

# -- Server Paths --------------------------------------------------------------
# Layout: /srv/umbra/{etc,deploy,runtime,data,backup}. This file is the template;
# on the server the real config lives at $ROOT_DIR/etc/.env (etc/ is the persistent
# operator-config home). deploy/ is disposable (CI rsyncs the subset there, no git
# clone); runtime/ is regenerated; data/ is the only backed-up state tree. REPO_DIR
# keeps its name (deploy scripts + contract reference it) and points at deploy/.
ROOT_DIR=/srv/umbra
REPO_DIR=/srv/umbra/deploy
RUNTIME_DIR=/srv/umbra/runtime
DATA_DIR=/srv/umbra/data
BACKUP_DIR=/srv/umbra/backup

# -- Domains -------------------------------------------------------------------
APEX_DOMAIN=ruyin.ai
WWW_DOMAIN=www.ruyin.ai
EDGE_DOMAIN=vpn.ruyin.ai
SUB_DOMAIN=sub.ruyin.ai
CONSOLE_DOMAIN=console.ruyin.ai
ADMIN_DOMAIN=admin.ruyin.ai
PASS_DOMAIN=pas.ruyin.ai

# -- Xray / REALITY ------------------------------------------------------------
XRAY_INTERNAL_PORT=10443
# Reality camouflage dest/SNI. Do NOT use www.microsoft.com: it is the most
# overused reality dest and was GFW-fingerprinted, causing intermittent handshake
# timeouts while node/route/DNS/MTU were all healthy. 2026-06-21 switched to
# www.icloud.com (less-common, China-reachable, Apple Tokyo edge, TLS1.3+h2). If
# this SNI is later flagged, pick another low-profile TLS1.3+h2 site or move to
# Hysteria2. SNI also threads through nginx stream map + Marzban host sni.
REALITY_DEST=www.icloud.com:443
REALITY_SNI=www.icloud.com
# Must be an even number; generates REALITY_SHORT_ID_LENGTH/2 random bytes as hex
REALITY_SHORT_ID_LENGTH=16

# -- Hysteria2 (UDP/QUIC fallback transport) -----------------------------------
# Standalone sidecar (Marzban's Xray core has no hysteria2). Listens UDP 443,
# reuses the EDGE_DOMAIN LE cert, salamander obfs. Injected into the Clash sub as
# vx-tokyo-h2 (shared-password auth) - the hedge if the reality SNI gets
# fingerprinted. Set real secrets in the server etc/.env (do not commit them).
HYSTERIA_PASSWORD=change-me-shared-hysteria-password
HYSTERIA_OBFS_PASSWORD=change-me-salamander-obfs-password

# -- Marzban -------------------------------------------------------------------
MARZBAN_ADMIN_USER=
MARZBAN_ADMIN_PASSWORD=
# public = trusted CA certs; private = temporary self-signed certs while waiting for LE rate limits
MARZBAN_SSL_CA_TYPE=public
# Base URL for subscription links - no trailing slash
SUBSCRIPTION_URL_PREFIX=https://sub.ruyin.ai
# Prefix used by umbra-subproxy for client-visible names: Ruyin-USERNAME.
SUB_PROFILE_PREFIX=Ruyin
# Upstream Marzban fallback title; subproxy rewrites the public response.
SUB_PROFILE_TITLE=Ruyin

# -- Account Portal ------------------------------------------------------------
# Generate each secret separately: openssl rand -base64 48
ACCOUNT_SESSION_SECRET=
ACCOUNT_INVITE_SECRET=
ACCOUNT_INVITE_TTL_DAYS=30
# Built-in admin portal (admin.ruyin.ai) credential, independent of Marzban.
ACCOUNT_ADMIN_USERNAME=
ACCOUNT_ADMIN_PASSWORD=
# Parent domain the opaque session cookie is shared on so one login covers
# ruyin.ai and every *.ruyin.ai app (apex; the leading-dot is implied). The
# account service clears the cookie on this domain at logout.
RUYIN_COOKIE_DOMAIN=ruyin.ai

# -- OIDC RP (Vxture App Integration Standard v1.0) ----------------------------
# ruyin is a cross-domain (mode B) OIDC Authorization-Code + PKCE RP against
# accounts.vxture.com, the single identity center for the whole product. The
# console portal is the RP / app-bff: it holds tokens server-side in Redis and
# the browser only ever sees an opaque session cookie. OIDC_ISSUER +
# OIDC_CLIENT_SECRET must both be set for login to work.
OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=ruyin
# Provisioned by the platform via secret manager; never commit the real value.
OIDC_CLIENT_SECRET=
# Must exactly match a registered redirect_uri on the ruyin oidc_client. The
# platform registers the APEX (standard section 11: RUYIN_BASE_URL=https://ruyin.ai),
# so nginx serves /auth/* on the apex by proxying to umbra-account-web (see
# 01-ruyin.conf.template). The callback host is the apex, not console.
OIDC_REDIRECT_URI=https://ruyin.ai/auth/callback
# Quote: the deploy sources .env via bash, which would word-split bare spaces.
# email/phone are required for the platform to release those claims (the ruyin
# client allows them); name/preferred_username/account_status ride profile.
OIDC_SCOPES="openid profile email phone ruyin"
# Post-logout landing; the apex marketing page is fine (anonymous, no loop).
OIDC_POST_LOGOUT_REDIRECT_URI=https://ruyin.ai/
# Server-side OIDC RP session store (umbra-redis on the compose network).
REDIS_URL=redis://umbra-redis:6379
# RP session lifetime in seconds (keep <= refresh TTL; default 30d).
RP_SESSION_TTL=2592000
# Opaque session cookie name + the first-party zone it is shared across.
RP_SESSION_COOKIE_NAME=vx_rp_session
RP_SESSION_COOKIE_DOMAIN=.ruyin.ai

# -- Vaultwarden ---------------------------------------------------------------
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# -- Certbot -------------------------------------------------------------------
CERTBOT_EMAIL=
# Set to true to use Let's Encrypt staging (untrusted certs, for pre-DNS testing)
CERTBOT_STAGING=false
# Set to true to skip certbot and use self-signed certs (no DNS required).
# Upgrade to real certs later: bash scripts/ops.sh certs --upgrade
CERTBOT_SKIP=false

# -- Post-deploy user creation (deploy.sh wizard) --------------------------------
USER_COUNT=10
USER_PREFIX=USER

# -- Nginx ---------------------------------------------------------------------
NGINX_CONTAINER=umbra-nginx

# -- Container Images ----------------------------------------------------------
# Production deployments should point IMAGE_REGISTRY to Aliyun ACR.
# Example: registry.cn-hangzhou.aliyuncs.com
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest

# -- Private packages ----------------------------------------------------------
# Published package source for @vxture/design-system.
# GitHub Packages default: https://npm.pkg.github.com
VXTURE_NPM_REGISTRY=https://npm.pkg.github.com
# Token with package read access. Keep only in .env or CI secrets.
NODE_AUTH_TOKEN=
