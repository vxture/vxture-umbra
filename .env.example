# ── Node Identity ─────────────────────────────────────────────────────────────
PROJECT_NAME=umbra
NODE_NAME=vx-tokyo

# ── Server Paths ──────────────────────────────────────────────────────────────
ROOT_DIR=/srv/vxture
REPO_DIR=/srv/vxture/repo/umbra
DATA_DIR=/srv/vxture/data/umbra
BACKUP_DIR=/srv/vxture/backup/umbra

# ── Domains ───────────────────────────────────────────────────────────────────
APEX_DOMAIN=ruyin.ai
WWW_DOMAIN=www.ruyin.ai
EDGE_DOMAIN=vpn.ruyin.ai
SUB_DOMAIN=sub.ruyin.ai
CONSOLE_DOMAIN=console.ruyin.ai
VAULT_DOMAIN=vault.ruyin.ai
STATUS_DOMAIN=status.ruyin.ai
DOCS_DOMAIN=docs.ruyin.ai
SHORTLINK_DOMAIN=go.ruyin.ai

# ── Xray / REALITY ────────────────────────────────────────────────────────────
XRAY_INTERNAL_PORT=10443
REALITY_DEST=www.microsoft.com:443
REALITY_SNI=www.microsoft.com
REALITY_SHORT_ID_LENGTH=16

# ── Marzban ───────────────────────────────────────────────────────────────────
MARZBAN_ADMIN_USER=
MARZBAN_ADMIN_PASSWORD=
# Nginx Basic Auth password for console.ruyin.ai (deploy-all.sh uses htpasswd -b)
CONSOLE_HTPASSWD_PASSWORD=
SUBSCRIPTION_URL_PREFIX=https://sub.ruyin.ai

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Fill these with strong random passwords: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_MARZBAN_PASSWORD=
POSTGRES_VAULTWARDEN_PASSWORD=
POSTGRES_SHLINK_PASSWORD=

# ── Vaultwarden ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# ── Certbot ───────────────────────────────────────────────────────────────────
CERTBOT_EMAIL=
# Set to true to use Let's Encrypt staging (untrusted certs, for pre-DNS testing)
CERTBOT_STAGING=false
# Set to true to skip certbot entirely and use self-signed certs (no DNS required)
# Replace later: rm -rf $DATA_DIR/letsencrypt && bash scripts/03-issue-certs.sh
CERTBOT_SKIP=false

# ── Shlink (Short Link) ───────────────────────────────────────────────────────
SHLINK_DEFAULT_DOMAIN=go.ruyin.ai

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_CONTAINER=umbra-nginx
